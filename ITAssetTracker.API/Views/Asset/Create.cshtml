@using ITAssetTracker.API
@using ITAssetTracker.API.Models
@using ITAssetTracker.API.Models.Asset
@model AssetForm
@{
	ViewData["Title"] = "Add Asset";

	if (TempData["Error"] != null)
	{
		<div>
			@TempData["Error"];
			<p>Asset not added. Something went wrong.</p>
		</div>
	}
}

<div class="container-fluid">
	<div class="row min-vh-100">
		<div class="d-none d-lg-block col-lg-2 border-end">
			Column
		</div>
		<div class="col-12 col-lg-7 p-4">
			<h1 class="m-0 fs-3">@ViewData["Title"]</h1>

			<form class="border rounded mt-3" asp-controller="Asset" asp-action="Create" method="post" novalidate>
				@* Form Header *@
				<div class="p-4 border-bottom">
					<div class="d-flex align-items-center gap-2">
						<i class="bi bi-box"></i>
						<h5 class="mb-0">Asset Information</h5>
					</div>
					<p class="mb-0 mt-2">Enter the details of the new asset.</p>
				</div>
				@Html.AntiForgeryToken()

				@* Form Input Fields *@
				<div class="p-4">
					<div class="row g-2">
						<div class="col">
							<label asp-for="Name" class="form-label">Asset Name<span class="required"> *</span></label>
							<input type="text" class="form-control" id="validationCustom01" placeholder="e.g. Dell Latitude 5420" asp-for="Name">
								<span class="text-danger" asp-validation-for="Name"></span>
							</div>
						<div class="col">
								<label asp-for="Tag" class="form-label">Asset Tag / ID<span class="required"> *</span></label>
							<input type="text" class="form-control" placeholder="e.g. 1001" asp-for="Tag">
									<span asp-validation-for="Tag" class="text-danger"></span>
							</div>
							
							</div>
							<div class="row g-2 mt-2">
								<div class="col">
									<label asp-for="AssetProductId" class="form-label">Model<span class="required"> *</span></label>
									<select class="form-select" aria-label="Default select example" asp-for="AssetProductId">
										<option selected disabled value="">Select Model</option>

										@foreach (var m in Model.AssetProductsList)
										{
											<option value="@m.AssetProductId">@m.Name</option>
										}

									</select>
									<span class="text-danger" asp-validation-for="AssetProductId"></span>
								</div>
								<div class="col">
									<label asp-for="AssetStatusId" class="form-label">Status<span class="required"> *</span></label>
									<select asp-for="AssetStatusId" class="form-select" aria-label="Default select example">
										<option selected disabled value="">Select status</option>

										@foreach (var at in Model.AssetStatusList)
										{
											<option value="@at.AssetStatusId">@at.Name</option>
										}

									</select>
									<span class="text-danger" asp-validation-for="AssetStatusId"></span>
								</div>
							</div>

							<div class="row g-2 mt-2">
								<div class="col">

									<label asp-for="Price" class="form-label">Price<span class="required"> *</span></label>
									<div class="input-group">
										<span class="input-group-text">£</span>
										<input class="form-control" placeholder="e.g. 1200.00" asp-for="Price">
									</div>
									<span class="text-danger" asp-validation-for="Price"></span>
								</div>
								<div class="col">
										<label asp-for="Location" class="form-label">Location<span class="required"> *</span></label>
										<input type="text" class="form-control" placeholder="e.g. Storage Cabinet 3" asp-for="Location">
										<span class="text-danger" asp-validation-for="Location"></span>
								</div>
							</div>
							<div class="row g-2 mt-2">
								<div class="col">
									<label asp-for="SerialNumber" class="form-label">Serial Number<span class="required"> *</span></label>
									<input type="text" class="form-control" placeholder="e.g. ABC123XYZ" asp-for="SerialNumber">
									<span class="text-danger" asp-validation-for="SerialNumber"></span>
								</div>
								<div class="col">
									<label asp-for="PurchaseDate" class="form-label">Purchase Date<span class="required"> *</span></label>
									<input type="date" class="form-control" placeholder="dd/mm/yyyy" asp-for="PurchaseDate">
									<span class="text-danger" asp-validation-for="PurchaseDate"></span>
								</div>
							</div>
								<div class="row g-2 mt-2">
									<div class="col">
										<label asp-for="WarrantyExpiryDate" class="form-label">Warranty Expiry Date<span class="required"> *</span></label>
										<input type="date" class="form-control" placeholder="dd/mm/yyyy" asp-for="WarrantyExpiryDate">
										<span class="text-danger" asp-validation-for="WarrantyExpiryDate"></span>
									</div>
									<div class="col">
									</div>
								</div>
							<div class="col mt-3">
								<label asp-for="Description" class="form-label">Description:</label>
								<textarea class="form-control" id="FormControlTextArea" placeholder="Enter any additional notes about the asset..." asp-for="Description"></textarea>
								<span class="text-danger" asp-validation-for="Description"></span>
							</div>
							<div class="buttons-section d-flex justify-content-between align-items-center mt-4">
													<label class="mb-0"><span class="required">* </span>Required Fields</label>
								<div class="d-flex gap-2">
														<a asp-controller="Asset" asp-action="Create" class="btn btn-secondary"><i class="bi bi-x"></i> Cancel</a>
									<button type="submit" class="btn btn-primary">Save Asset</button>
								</div>
							</div>
						</div>
					</form>
				</div>

@* Info Section *@
<div class="col-12 col-lg-3 p-4">
	<div class="border rounded p-3 mt-lg-5">
		<div class="d-flex align-items-center gap-2 mb-3">
			<i class="bi bi-info-circle"></i>
			<h6 class="mb-0">About Assets</h6>
		</div>
		<p>Assets are physical or virtual items that are tracked by the organisation.</p>
		<p>Examples:</p>
		<ul>
			<li>Laptops</li>
			<li>Desktops</li>
			<li>Monitors</li>
			<li>Printers</li>
			<li>Network Devices</li>
			<li>Software Licenses</li>
		</ul>
			</div>
		</div>
	</div>
</div>

