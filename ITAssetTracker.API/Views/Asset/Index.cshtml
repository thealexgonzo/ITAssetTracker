@using ITAssetTracker.API
@using ITAssetTracker.API.Models
@using ITAssetTracker.API.Models.Asset
@model AssetList
@{
    ViewData["Title"] = "Assets";

    if (TempData["Success"] != null)
    {
        <div class="alert alert-success" role="alert">
            @TempData["Success"];
        </div>
    }
}

<h1 class="mb-3">Asset Search</h1>
<p class="mb-3">Search for an asset by tag number or leave blank to return all assets.</p>
@* <p class="mb-3">You may also <a asp-controller="Assets" asp-action="Create">create an asset</a>.</p> *@
<form asp-controller="Asset" asp-action="Index" method="post" class="mb-3">
    @Html.AntiForgeryToken()
    <div class="mb-3 col-md-3">
        <label asp-for="SearchTag" class="form-label">Enter Tag Number:</label>
        <input type="text" class="form-control" asp-for="SearchTag">
        </div>
        <button type="submit" class="btn btn-primary">Search</button>
        @* <button class="btn btn-primary" asp-controller="Asset" asp-action="Create">Create New</button> *@
        <a asp-controller="Asset" asp-action="Create" class="btn btn-outline-primary">Create New</a>

        <!-- Button trigger modal -->
        <button type="button" class="btn btn-primary" data-toggle="modal" data-target="#exampleModal">
            Launch demo modal
        </button>

        <!-- Modal -->
        <div class="modal fade" id="exampleModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="exampleModalLabel">Modal title</h5>
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        ...
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                        <button type="button" class="btn btn-primary">Save changes</button>
                    </div>
                </div>
            </div>
        </div>


</form>
    @if (Model.Assets != null)
    {
        <table class="table table-striped table-light">
            <thead>
                <tr>
                    <th>Tag</th>
                    <th>Name</th>
                    <th>Model</th>
                    <th>Description</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>            
            @foreach (var asset in Model.Assets)
            {
                <tr>
                    <td>@asset.Tag</td>
                    <td>@asset.Name</td>
                    <td>@asset.AssetProducts.Name</td>
                    <td>@asset.Description</td>
                    <td>
                        <a class="btn btn-primary btn-sm" asp-controller="Asset" asp-action="Details" asp-route-id="@asset.AssetId">Details</a>
                        <a class="btn btn-secondary btn-sm" asp-controller="Asset" asp-action="Edit" asp-route-id="@asset.AssetId">Edit</a>
                        <a class="btn btn-danger btn-sm" asp-controller="Asset" asp-action="Delete" asp-route-id="@asset.AssetId">Delete</a>
                    </td>
                </tr>
            }                            
            </tbody>
        </table>
    }
